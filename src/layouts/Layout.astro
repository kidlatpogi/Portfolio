---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Zeus Angelo Bautista", 
	description = "Architecting high-fidelity digital experiences. Personal portfolio of Zeus Angelo Vargas Bautista, IT Developer & AI Engineer." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth preloading">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/Logo Black.svg" media="(prefers-color-scheme: light)" />
		<link rel="icon" type="image/svg+xml" href="/Logo White.svg" media="(prefers-color-scheme: dark)" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Primary SEO Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
 
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
 
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
 
		<!-- Google Fonts & Icons -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Roboto+Mono:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Roboto+Mono:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" media="print" onload="this.media='all'" />
		<noscript>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Roboto+Mono:wght@400;500;600;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" />
		</noscript>
	</head>
	<body class="bg-[#f8f8f8] text-black antialiased selection:bg-[#DF2935]/20 selection:text-black overflow-x-hidden min-h-screen">
		<!-- Preloader Overlay (good-fella.com style) -->
		<div id="preloader" class="fixed inset-0 z-[99999] overflow-hidden pointer-events-none">
			<!-- Orange sweep layer using the website's burnt orange accent color (#C44900) -->
			<div id="preloader-orange" class="fixed top-[-50vh] left-[-50vw] w-[200vw] h-[200vh] bg-[#C44900] z-[99997] pointer-events-auto" style="transform: rotate(-30deg) translateY(0%); transform-origin: center center; will-change: transform;"></div>
			<!-- Black sweep layer -->
			<div id="preloader-black" class="fixed top-[-50vh] left-[-50vw] w-[200vw] h-[200vh] bg-black z-[99998] pointer-events-auto" style="transform: rotate(-30deg) translateY(0%); transform-origin: center center; will-change: transform;"></div>
			
			<!-- Centered text container (remains horizontal and centered) -->
			<div id="preloader-text-container" class="fixed inset-0 flex items-center justify-center z-[99999] pointer-events-auto">
				<div class="relative font-mono font-bold text-[6vw] sm:text-[4vw] md:text-[3vw] lg:text-[2.2vw] xl:text-[1.8vw] tracking-[0.25em] uppercase select-none">
					<!-- Glitch shadow in burnt orange -->
					<div class="absolute inset-0 text-[#C44900] opacity-35 blur-[2.5px] pointer-events-none select-none glitch-text translate-x-[2px] translate-y-[1px]"></div>
					<!-- Main white text -->
					<div id="preloader-text" class="relative text-white z-10"></div>
				</div>
			</div>
		</div>

		<script is:inline>
			(function() {
				const chars = '!<>-_\\/[]{}—=+*^?#________';
				const targetText = 'LOADING';
				const textEl = document.getElementById('preloader-text');
				const shadowEl = document.querySelector('.glitch-text');

				if (!textEl) return;

				class Scrambler {
					constructor(el, shadowEl) {
						this.el = el;
						this.shadowEl = shadowEl;
						this.frame = 0;
						this.queue = [];
						this.resolve = null;
					}
					scramble(text) {
						const promise = new Promise((r) => this.resolve = r);
						this.queue = [];
						for (let i = 0; i < text.length; i++) {
							const to = text[i];
							const start = Math.floor(Math.random() * 20);
							const end = start + Math.floor(Math.random() * 25) + 10;
							this.queue.push({ to, start, end, char: '' });
						}
						this.frame = 0;
						this.tick();
						return promise;
					}
					tick() {
						let output = '';
						let complete = 0;
						for (let i = 0; i < this.queue.length; i++) {
							let { to, start, end, char } = this.queue[i];
							if (this.frame >= end) {
								complete++;
								output += to;
							} else if (this.frame >= start) {
								if (!char || Math.random() < 0.28) {
									char = chars[Math.floor(Math.random() * chars.length)];
									this.queue[i].char = char;
								}
								// Our burnt orange color for the scramble character
								output += `<span style="color: #C44900;">${char}</span>`;
							} else {
								output += '';
							}
						}
						this.el.innerHTML = output;
						if (this.shadowEl) {
							this.shadowEl.innerHTML = output;
						}

						if (complete === this.queue.length) {
							if (this.resolve) this.resolve();
						} else {
							this.frame++;
							requestAnimationFrame(() => this.tick());
						}
					}
				}

				const scrambler = new Scrambler(textEl, shadowEl);
				scrambler.scramble(targetText);

				let isLoaded = false;
				let isMinTimeElapsed = false;

				window.addEventListener('load', () => {
					isLoaded = true;
					checkRemoval();
				});

				setTimeout(() => {
					isMinTimeElapsed = true;
					checkRemoval();
				}, 2500);

				function checkRemoval() {
					if (isLoaded && isMinTimeElapsed) {
						const textContainer = document.getElementById('preloader-text-container');
						if (textContainer) {
							textContainer.style.transition = 'opacity 0.4s ease';
							textContainer.style.opacity = '0';
							document.documentElement.classList.remove('preloading');
							
							// Dispatch finish event right when text starts fading so background sweep overlays nicely
							window.dispatchEvent(new CustomEvent('preloaderFinished'));
							
							setTimeout(() => {
								textContainer.remove();
							}, 400);
						}
					}
				}
			})();
		</script>

		<slot />
	</body>
</html>

<style is:global>
	:root {
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
		scrollbar-width: none; /* Hide scrollbar for Firefox */
		-ms-overflow-style: none; /* Hide scrollbar for IE and Edge */
	}
	
	html::-webkit-scrollbar,
	body::-webkit-scrollbar {
		display: none; /* Hide scrollbar for Chrome, Safari, and Opera */
	}

	html.preloading,
	html.preloading body {
		overflow: hidden !important;
		height: 100% !important;
	}

	html.preloading nav,
	html.preloading header,
	html.preloading main {
		opacity: 0 !important;
	}

	.hero-subtitle,
	.hero-title-1,
	.hero-title-2,
	.hero-title-3,
	.hero-socials {
		opacity: 0;
	}
</style>

<script>
	import Lenis from 'lenis';
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// Initialize Lenis smooth scroll
	const lenis = new Lenis({
		duration: 1.2,
		easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
		smoothWheel: true,
	});

	// Sync ScrollTrigger with Lenis
	lenis.on('scroll', ScrollTrigger.update);

	gsap.ticker.add((time) => {
		lenis.raf(time * 1000);
	});

	gsap.ticker.lagSmoothing(0);

	// Stop scroll initially while preloader is active
	lenis.stop();

	// Animate reveal of navigation and main sections once preloader is finished
	window.addEventListener('preloaderFinished', () => {
		lenis.start();

		// Sync scroll position instantly behind the preloader curtain if there is a hash
		if (window.location.hash) {
			const targetEl = document.querySelector(window.location.hash);
			if (targetEl) {
				lenis.scrollTo(targetEl as HTMLElement, { immediate: true });
				
				// Fallback native scroll to be 100% robust
				const rect = targetEl.getBoundingClientRect();
				const absoluteTop = rect.top + window.pageYOffset;
				window.scrollTo(0, absoluteTop);
			}
		}

		// Recalculate GSAP ScrollTrigger offsets once the preloading layout shifts have settled
		setTimeout(() => {
			ScrollTrigger.refresh();
		}, 1800);

		const tl = gsap.timeline({
			onComplete: () => {
				document.getElementById('preloader')?.remove();
				window.dispatchEvent(new CustomEvent('preloaderFullyRemoved'));
			}
		});

		// Sweep black layer (to local translateY 120% which is off-screen down-right)
		tl.to('#preloader-black', {
			yPercent: 120,
			duration: 1.5,
			ease: 'power3.inOut'
		});

		// Sweep orange layer with slight delay and slightly longer/offset timeline
		tl.to('#preloader-orange', {
			yPercent: 120,
			duration: 1.7,
			ease: 'power3.inOut'
		}, 0.12); // starts 120ms after the black layer starts

		// Reveal Hero content container if it exists
		const homeEl = document.getElementById('home');
		if (homeEl) {
			tl.fromTo(homeEl, 
				{ opacity: 0 },
				{ opacity: 1, duration: 0.1 },
				'-=1.1'
			);
		}

		// Staggered reveal of hero text lines & socials if they exist
		const heroElements = document.querySelectorAll('.hero-subtitle, .hero-title-1, .hero-title-2, .hero-title-3, .hero-socials');
		if (heroElements.length > 0) {
			tl.fromTo(Array.from(heroElements),
				{ opacity: 0, y: 40 },
				{ opacity: 1, y: 0, duration: 1.4, ease: 'power4.out', stagger: 0.12 },
				'-=1.1'
			);
		}

		// Reveal Navbar if it exists
		const navEl = document.querySelector('.fixed.top-6');
		if (navEl) {
			tl.fromTo(navEl, 
				{ opacity: 0, y: -40 },
				{ opacity: 1, y: 0, duration: 1.1, ease: 'power3.out' },
				'-=0.9'
			);
		}

		// Staggered reveal for subpages (e.g. /projects)
		if (!homeEl) {
			const subpageElements = document.querySelectorAll('nav, header, main');
			if (subpageElements.length > 0) {
				tl.fromTo(Array.from(subpageElements),
					{ opacity: 0, y: 35 },
					{ opacity: 1, y: 0, duration: 1.2, ease: 'power3.out', stagger: 0.12 },
					'-=1.2'
				);
			}
		}
	});
</script>
