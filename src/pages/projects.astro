---
import Layout from '../layouts/Layout.astro';
import TargetCursor from '../components/TargetCursor.tsx';
import ShapeGrid from '../components/ShapeGrid.tsx';

const projects = [
  {
    title: "Bigkas Capstone",
    year: "2025",
    isFeatured: true,
    description: "A speech rehabilitation and therapy mobile/web application utilizing speech-to-text recognition models to assist children with speech impediments in practicing pronunciation.",
    tags: ["React", "Node.js", "Web Speech API", "Tailwind CSS"],
    stack: "[REACT] — [NODE.JS]",
    color: "#4f46e5",
    github: "https://github.com/kidlatpogi/bigkas-capstone",
    link: "https://bigkas.site/",
    image: "",
    backupImage: ""
  },
  {
    title: "L.I.N.N.Y",
    year: "2024",
    isFeatured: true,
    description: "An offline voice assistant and automation tool utilizing local natural language processing models to perform system-level tasks and tasks automation without internet dependencies.",
    tags: ["Python", "PyTorch", "Vosk NLP", "Speech Recognition"],
    stack: "[PYTHON] — [PYTORCH]",
    color: "#0f172a",
    github: "https://github.com/kidlatpogi/L.I.N.N.Y",
    link: "",
    image: "https://zeusbautista.site/Project%20Overview/Linny-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/Linny-1200.webp"
  },
  {
    title: "SafeLink",
    year: "2024",
    isFeatured: false,
    description: "A cyber-security tool and link analyzer that parses URLs to detect phishing sites, malware redirects, and shortener tracking cookies in real-time.",
    tags: ["FastAPI", "React", "Python", "VirusTotal API"],
    stack: "[FASTAPI] — [REACT]",
    color: "#022c22",
    github: "https://github.com/kidlatpogi/SafeLink",
    link: "",
    image: "https://zeusbautista.site/Project%20Overview/SafeLink-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/SafeLink-1200.webp"
  },
  {
    title: "Calendar Widget",
    year: "2024",
    isFeatured: false,
    description: "A highly customizable desktop calendar and productivity widget displaying schedule overlays, weather forecast, and system status widgets.",
    tags: ["Electron", "JavaScript", "HTML5", "CSS3"],
    stack: "[ELECTRON] — [JS]",
    color: "#172554",
    github: "https://github.com/kidlatpogi/Calendar-Widget",
    link: "",
    image: "https://zeusbautista.site/Project%20Overview/CalendarWidget-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/CalendarWidget-1200.webp"
  },
  {
    title: "My-PC InfoSec E-Commerce",
    year: "2024",
    isFeatured: true,
    description: "A secure e-commerce application designed with robust protection inputs against SQL injections, XSS attacks, and CSRF attempts, managing hardware transactions safely.",
    tags: ["React", "Express", "Node.js", "MongoDB", "JWT Security"],
    stack: "[REACT] — [EXPRESS]",
    color: "#C44900",
    github: "https://github.com/kidlatpogi/InfoSec-MyPC",
    link: "https://mypcinfosec.vercel.app/",
    image: "https://zeusbautista.site/Project%20Overview/MyPC-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/MyPC-1200.webp"
  },
  {
    title: "WebToolz",
    year: "2024",
    isFeatured: false,
    description: "A comprehensive developer toolkit compilation offering formatting converters, hash generators, regex testing utility panels, and API payload formatters.",
    tags: ["Vite", "React", "TypeScript", "Tailwind CSS"],
    stack: "[REACT] — [VITE]",
    color: "#581c87",
    github: "https://github.com/kidlatpogi/Web-tools",
    link: "https://wtoolz.vercel.app/",
    image: "https://zeusbautista.site/Project%20Overview/WebToolz-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/WebToolz-1200.webp"
  },
  {
    title: "Gnosis Recall",
    year: "2024",
    isFeatured: true,
    description: "An active recall and Spaced Repetition flashcard system helping students optimize cognitive retention for academic studies using smart algorithm schedules.",
    tags: ["Next.js", "Firebase", "React", "OpenAI GPT API"],
    stack: "[NEXT.JS] — [FIREBASE]",
    color: "#0b0f19",
    github: "https://github.com/kidlatpogi/Gnosis",
    link: "https://gnosis-study.vercel.app/",
    image: "https://zeusbautista.site/Project%20Overview/Gnosis-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/Gnosis-1200.webp"
  },
  {
    title: "Room Reservation",
    year: "2024",
    isFeatured: false,
    description: "An enterprise room and workspaces reservation system handling schedule clashes, resources allocation, and automated booking notifications.",
    tags: ["Java", "Spring Boot", "React", "MySQL"],
    stack: "[JAVA] — [REACT]",
    color: "#312e81",
    github: "https://github.com/kidlatpogi/Room-Reservation-System",
    link: "",
    image: "https://zeusbautista.site/Project%20Overview/RoomReservationSystem-1200.webp",
    backupImage: "https://pub-6be64aebeca647248b39162d6d6633f8.r2.dev/Project%20Overview/RoomReservationSystem-1200.webp"
  }
];
---

<Layout title="All Projects — Zeus Angelo">
  <!-- Background ShapeGrid -->
  <div class="fixed inset-0 z-0 pointer-events-none">
    <ShapeGrid client:load speed={0} squareSize={55} borderColor="rgba(51, 65, 85, 0.05)" hoverFillColor="rgba(51, 65, 85, 0.12)" shape="square" hoverTrailAmount={6} gradientColor="#f8f8f8" />
  </div>

  <TargetCursor client:only="react" targetSelector="a, button, .cursor-target" />

  <div class="relative z-10 w-full min-h-screen flex flex-col pt-16 pb-24 px-6 md:px-16 lg:px-24 max-w-[1600px] mx-auto overflow-x-hidden">
    
    <!-- Top Back Navigation -->
    <nav class="w-full flex items-center justify-between mb-16 md:mb-24 flex-shrink-0">
      <a href="/#projects" class="group flex items-center gap-2 font-mono text-xs md:text-sm uppercase tracking-[0.15em] font-bold bg-[#C44900] text-white px-5 py-2.5 rounded-full shadow-sm cursor-target">
        ← Back to Projects
      </a>
      <span class="font-mono text-xs md:text-sm uppercase tracking-[0.2em] font-semibold text-slate-800">
        Zeus Angelo
      </span>
    </nav>

    <!-- Header Section -->
    <header class="w-full mb-16 flex flex-col items-start gap-4">
      <span class="font-mono text-xs md:text-sm uppercase tracking-[0.25em] font-bold text-accent">
        Portfolio
      </span>
      <h1 class="font-clash-bold text-5xl sm:text-6xl md:text-7xl lg:text-[3.5rem] xl:text-[4.5rem] 2xl:text-[5.5rem] font-bold uppercase tracking-tight leading-[0.85] text-slate-900 select-none">
        All Projects
      </h1>
      <p class="font-sans text-base md:text-lg text-slate-600 max-w-xl leading-relaxed mt-2">
        Full list of work—same craft as the featured section. Explore details and repositories for the full case studies.
      </p>
    </header>

    <!-- Grid Layout -->
    <main class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 flex-grow">
      {projects.map((project, index) => (
        <article class="flex flex-col group overflow-hidden border border-slate-200/50 rounded-xl bg-white shadow-sm hover:shadow-lg transition-all duration-300">
          
          {/* Card Visual Header */}
          <div 
            style={`background-color: ${project.color}`}
            class="w-full aspect-[16/10] relative overflow-hidden flex items-center justify-center select-none"
          >
            {project.image ? (
              <img 
                src={project.image} 
                alt={`${project.title} preview`}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
                onerror={`this.onerror=null; this.src='${project.backupImage || ''}';`}
              />
            ) : (
              <!-- Large Translucent Index Number -->
              <span class="text-white/10 font-sans text-7xl sm:text-8xl md:text-[5.5rem] lg:text-8xl font-black tracking-tighter group-hover:scale-105 transition-transform duration-500">
                0{index + 1}
              </span>
            )}

            <!-- Year Pill & Tags overlay -->
            <div class="absolute top-4 left-4 flex gap-2">
              <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded bg-black/40 text-white backdrop-blur-sm">
                {project.year}
              </span>
              {project.isFeatured && (
                <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded bg-accent text-white font-bold">
                  Featured
                </span>
              )}
            </div>
          </div>

          {/* Card Info Section */}
          <div class="flex flex-col p-6 flex-grow gap-4">
            <div>
              <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-accent font-bold">
                {project.stack}
              </span>
              <h2 class="font-clash-bold text-xl md:text-2xl font-bold text-slate-900 uppercase tracking-tight mt-1 group-hover:text-accent transition-colors duration-300">
                {project.title}
              </h2>
            </div>
            
            <p class="font-sans text-sm text-slate-500 leading-relaxed flex-grow">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-1.5 mt-2">
              {project.tags.map((tag) => (
                <span class="font-mono text-[10px] uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-600 border border-slate-200/50">
                  {tag}
                </span>
              ))}
            </div>

            {/* Action Links */}
             <div class="flex items-center justify-between border-t border-slate-100 pt-4 mt-2">
               <a href={project.github} target="_blank" rel="noopener noreferrer" class="font-mono text-xs uppercase tracking-wider text-slate-400 hover:text-slate-900 transition-colors flex items-center gap-1 cursor-target">
                 GitHub Repo
               </a>
               {project.link && (
                 <a href={project.link} target="_blank" rel="noopener noreferrer" class="font-mono text-xs uppercase tracking-wider text-accent hover:text-slate-900 transition-colors flex items-center gap-1 font-bold cursor-target">
                   Live Demo →
                 </a>
               )}
             </div>

          </div>
        </article>
      ))}
    </main>

  </div>
</Layout>
